{
  "name": "prox-gallery-admin-ui",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.admin.config.js",
    "build": "vite build --config vite.admin.config.js",
    "preview": "vite preview --config vite.admin.config.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"assets/admin/src/**/*.{ts,tsx}\"",
    "readability:frontend": "eslint \"assets/admin/src/**/*.{ts,tsx}\" --max-warnings=0",
    "readability:backend": "composer fix:check && composer analyse",
    "semgrep": "./bin/semgrep --config semgrep.yml --error",
    "readability": "npm run readability:frontend && npm run readability:backend",
    "check": "npm run lint && npm run typecheck && npm run build",
    "quality": "npm run check && composer check",
    "shadcn:add": "npx shadcn@latest add button card badge tabs table"
  },
  "dependencies": {
    "@radix-ui/react-slot": "latest",
    "@radix-ui/react-tabs": "latest",
    "class-variance-authority": "latest",
    "clsx": "latest",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "tailwind-merge": "latest"
  },
  "devDependencies": {
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@eslint/js": "^9.22.0",
    "@tailwindcss/vite": "latest",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "@vitejs/plugin-react": "latest",
    "eslint": "^9.22.0",
    "globals": "^15.15.0",
    "tailwindcss": "latest",
    "typescript": "^5.8.2",
    "vite": "latest"
  }
}
